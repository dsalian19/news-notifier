# Copy this file to .env and fill in your local values.
# Never commit .env — it is gitignored.
#
# For production (Render), set these as environment variables
# in the Render dashboard under your service's Environment tab.
# Use the JDBC format for DATABASE_URL (prefix with jdbc:):
#   jdbc:postgresql://<host>/<dbname>

DATABASE_URL=jdbc:postgresql://localhost:5432/news_notifier
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Generate with: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=your_base64_encoded_secret
JWT_EXPIRATION_MS=86400000

# Get your free key at https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=your_guardian_api_key_here
